NODE_ENV=development
PORT=3000
HOST=127.0.0.1

# Use a long random value in production.
JWT_SECRET=change-this-to-a-long-random-secret

# Optional for local development. If empty, the app uses db.json.
# Railway production should set this in Railway Variables, not in GitHub.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/library-seat-management?retryWrites=true&w=majority
MONGODB_DB_NAME=library-seat-management

# Used only when a new database is created.
ADMIN_DEFAULT_PASSWORD=admin

# Public app URL after deployment.
APP_URL=http://localhost:3000
